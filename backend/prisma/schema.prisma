generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  password        String?
  role            Role      @default(STUDENT)
  active          Boolean   @default(true)
  sourceStudentId String?
  leadReservationLimitOverride    Int?
  blockNewLeadsAfterWonOverride   Boolean?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignedLeads   Lead[]         @relation("AssignedLeads")
  comments        LeadComment[]
  history         LeadHistory[]
  reminders       Reminder[]
  callAnalyses    CallAnalysis[]
  releaseRequests LeadReleaseRequest[] @relation("LeadReleaseRequester")
  reviewedReleaseRequests LeadReleaseRequest[] @relation("LeadReleaseReviewer")
  uploadedLeadCallRecords LeadCallRecord[] @relation("LeadCallRecordUploader")
  leadAiConversations LeadAiConversation[]
  voiceJourneys   VoicePracticeJourney[]

  @@map("users")
}

model Lead {
  id           String     @id @default(cuid())
  name         String
  phone        String
  service      String?
  source       String?
  budget       String?
  status       LeadStatus @default(AVAILABLE)
  notes        String?
  lostReason   String?
  aiProfileSummary  String?   @db.Text
  aiProfileInsights Json?
  assignedTo   User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  assignedToId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  comments     LeadComment[]
  history      LeadHistory[]
  reminders    Reminder[]
  releaseRequests LeadReleaseRequest[]
  callRecords LeadCallRecord[]
  aiConversations LeadAiConversation[]

  @@map("leads")
}

model LeadComment {
  id          String   @id @default(cuid())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  commentText String
  createdAt   DateTime @default(now())

  @@map("lead_comments")
}

model LeadHistory {
  id         String   @id @default(cuid())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId     String
  actor      User     @relation(fields: [actorId], references: [id])
  actorId    String
  actionType String
  fromValue  String?
  toValue    String?
  createdAt  DateTime @default(now())

  @@map("lead_history")
}

model Reminder {
  id        String         @id @default(cuid())
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  createdBy User           @relation(fields: [createdById], references: [id])
  createdById String
  dueAt     DateTime
  status    ReminderStatus @default(PENDING)
  note      String?
  createdAt DateTime       @default(now())

  @@map("reminders")
}

model CallAnalysis {
  id           String   @id @default(cuid())
  studentId    String
  student      User     @relation(fields: [studentId], references: [id])
  score        Int      
  transcript   String   @db.Text
  feedback     String   @db.Text 
  durationSec  Int?
  createdAt    DateTime @default(now())

  @@map("call_analyses")
}

model LeadReleaseRequest {
  id           String                   @id @default(cuid())
  lead         Lead                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId       String
  student      User                     @relation("LeadReleaseRequester", fields: [studentId], references: [id])
  studentId    String
  status       LeadReleaseRequestStatus @default(PENDING)
  studentNote  String?                  @db.Text
  adminNote    String?                  @db.Text
  reviewedBy   User?                    @relation("LeadReleaseReviewer", fields: [reviewedById], references: [id])
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([leadId, status])
  @@index([studentId, status])
  @@map("lead_release_requests")
}

model LeadCallRecord {
  id               String     @id @default(cuid())
  lead             Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId           String
  uploadedBy       User       @relation("LeadCallRecordUploader", fields: [uploadedById], references: [id])
  uploadedById     String
  fileName         String?
  transcript       String     @db.Text
  summary          String     @db.Text
  extractedProfile Json?
  nextStep         String?    @db.Text
  suggestedStatus  LeadStatus?
  createdAt        DateTime   @default(now())

  @@index([leadId, createdAt])
  @@map("lead_call_records")
}

model SyncLog {
  id        String   @id @default(cuid())
  syncType  String
  result    String
  syncedAt  DateTime @default(now())

  @@map("sync_logs")
}

model LeadAiConversation {
  id        String          @id @default(cuid())
  leadId    String
  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  messages  LeadAiMessage[]

  @@unique([leadId, userId])
  @@index([userId, updatedAt])
  @@map("lead_ai_conversations")
}

model LeadAiMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   LeadAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           LeadAiMessageRole
  content        String            @db.Text
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@map("lead_ai_messages")
}

// Key-value store for admin-configurable system settings
// Overrides env vars at runtime (DB takes precedence over .env)
model SystemSetting {
  key         String   @id          // e.g. "TWOCHAT_API_KEY"
  value       String   @db.Text     // the actual value
  label       String                // human-readable label (Arabic)
  description String?               // optional hint
  sensitive   Boolean  @default(false) // mask value in API responses
  updatedAt   DateTime @updatedAt
  updatedById String?               // which admin last changed it

  @@map("system_settings")
}

model VoicePracticeJourney {
  id              String                     @id @default(cuid())
  studentId       String
  student         User                       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  clientName      String
  clientRole      String
  businessName    String
  industry        String
  location        String
  dialect         String
  stage           VoicePracticeStage         @default(FIRST_OUTREACH)
  status          VoicePracticeJourneyStatus @default(ACTIVE)
  publicBrief     String?                    @db.Text
  historySummary  String?                    @db.Text
  profile         Json
  discoveredFacts Json?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  calls           VoicePracticeCall[]

  @@map("voice_practice_journeys")
}

model VoicePracticeCall {
  id          String                  @id @default(cuid())
  journeyId   String
  journey     VoicePracticeJourney    @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  stage       VoicePracticeStage
  status      VoicePracticeCallStatus @default(IN_PROGRESS)
  startedAt   DateTime                @default(now())
  endedAt     DateTime?
  durationSec Int?
  transcript  String?                 @db.Text
  summary     String?                 @db.Text
  score       Int?
  review      Json?
  createdAt   DateTime                @default(now())

  @@map("voice_practice_calls")
}

enum Role {
  ADMIN
  STUDENT
}

enum LeadStatus {
  AVAILABLE
  TAKEN
  CONTACTED
  FOLLOW_UP
  QUALIFIED
  CLOSED_WON
  CLOSED_LOST
}

enum ReminderStatus {
  PENDING
  DONE
  OVERDUE
}

enum LeadReleaseRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VoicePracticeStage {
  FIRST_OUTREACH
  DISCOVERY_CALL
  QUALIFICATION_CALL
  OFFER_CALL
  FOLLOW_UP_CALL
  CLOSING_CALL
}

enum VoicePracticeJourneyStatus {
  ACTIVE
  WON
  LOST
  ARCHIVED
}

enum VoicePracticeCallStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum LeadAiMessageRole {
  USER
  ASSISTANT
}
